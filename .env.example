# Private Discover environment variables.
# .env is gitignored. Shell exports always win over values in this file.
#
# Examples:
#   1. cp .env.example .env
#   2. mkdir -p ~/.discover && cp .env.example ~/.discover/.env
#
# Optional: NVD API key for faster CVSS lookups during Active recon.
# Request a free key: https://nvd.nist.gov/developers/request-an-api-key
#
# NVD_API_KEY=your-key-here
#
# Optional: Shodan API key for post-Active host enrichment (Domain menu 11).
# Membership or higher: https://account.shodan.io / https://www.shodan.io/store/member
# IP host lookups do not consume query credits.
#
# SHODAN_API_KEY=your-key-here

